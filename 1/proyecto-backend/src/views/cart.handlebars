<div style="max-width: 800px; margin: 2rem auto; background: white; padding: 2rem; border-radius: 0.5rem; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
    <a href="/products" style="color: #6b7280; text-decoration: none; font-weight: 500;">← Seguir comprando</a>
    
    <h1 style="color: #0b5f1e; margin: 1.5rem 0 2rem 0; font-weight: 700;">Tu Carrito</h1>

    <!-- GUARDAMOS EL CART ID ACÁ DE FORMA INVISIBLE PARA USARLO EN JS -->
    <input type="hidden" id="activeCartId" value="{{cart._id}}">

    {{#if cart.products.length}}
        <div>
            {{#each cart.products}}
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 1.5rem 0; border-bottom: 1px solid #e5e7eb;">
                    <!-- Info del producto -->
                    <div style="flex: 2;">
                        <h3 style="margin: 0 0 0.25rem 0; font-size: 1.1rem; font-weight: 600;">{{this.product.title}}</h3>
                        <p style="margin: 0; color: #6b7280; font-size: 0.9rem;">Precio unitario: ${{this.product.price}}</p>
                    </div>
                    
                    <!-- Controles de cantidad y eliminar -->
                    <div style="flex: 1; display: flex; align-items: center; justify-content: flex-end; gap: 1.5rem;">
                        
                        <!-- Input para cambiar cantidad (AHORA SOLO PASA EL PRODUCT ID) -->
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <label style="font-weight: 600; font-size: 0.9rem;">Cant:</label>
                            <input type="number" 
                                   value="{{this.quantity}}" 
                                   min="1"
                                   onchange="updateQuantity('{{this.product._id}}', this.value)"
                                   style="width: 60px; padding: 0.25rem; border: 1px solid #d1d5db; border-radius: 0.375rem; text-align: center; font-family: 'Poppins', sans-serif;">
                        </div>

                        <!-- Botón para eliminar un solo producto -->
                        <button onclick="removeProduct('{{this.product._id}}')" 
                                style="background-color: transparent; border: none; color: #dc2626; cursor: pointer; font-size: 1.2rem; padding: 0.25rem; transition: transform 0.2s;"
                                title="Eliminar producto">
                            x
                        </button>

                    </div>
                </div>
            {{/each}}
        </div>
        
        <!-- Botón para vaciar TODO el carrito -->
        <div style="margin-top: 2rem; text-align: right;">
            <button onclick="emptyCart()" style="background-color: #ef4444; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 0.375rem; cursor: pointer; font-weight: 600; transition: background-color 0.2s;">
                Vaciar Carrito Completo
            </button>
        </div>
    {{else}}
        <div style="text-align: center; padding: 4rem 0;">
            <h3 style="color: #6b7280; font-weight: 500;">Tu carrito está vacío 🛒</h3>
            <a href="/products" style="display: inline-block; margin-top: 1rem; padding: 0.75rem 1.5rem; background: #0b5f1e; color: white; text-decoration: none; border-radius: 0.375rem; font-weight: 600;">Ir a comprar</a>
        </div>
    {{/if}}
</div>

<script>
    // Recuperamos el ID del carrito del input oculto
    const cartId = document.getElementById('activeCartId').value;

    async function updateQuantity(productId, newQuantity) {
        if(newQuantity < 1) return;
        
        try {
            const response = await fetch(`/api/carts/${cartId}/products/${productId}`, { 
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ quantity: parseInt(newQuantity) })
            });
            
            if (response.ok) {
                Toastify({
                    text: "Cantidad actualizada ✅",
                    duration: 2000,
                    gravity: "bottom", position: "right",
                    style: { background: "#0b5f1e", borderRadius: "8px", fontFamily: "Poppins, sans-serif" }
                }).showToast();
            } else {
                Toastify({
                    text: "Error al actualizar",
                    duration: 2000,
                    gravity: "bottom", position: "right",
                    style: { background: "#dc2626", borderRadius: "8px", fontFamily: "Poppins, sans-serif" }
                }).showToast();
            }
        } catch (error) {
            console.error(error);
        }
    }

       async function removeProduct(productId) {
        // Modal de confirmación de SweetAlert2
        const result = await Swal.fire({
            title: '¿Eliminar producto?',
            text: "Se quitará este artículo de tu carrito",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc2626',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar'
        });

        // Si el usuario toca "Sí, eliminar"
        if (result.isConfirmed) {
            try {
                const response = await fetch(`/api/carts/${cartId}/products/${productId}`, { method: 'DELETE' });
                if (response.ok) {
                    Toastify({ text: "Producto eliminado 🗑️", duration: 1500, style: { background: "#f59e0b", borderRadius: "8px" } }).showToast();
                    setTimeout(() => window.location.reload(), 1500);
                }
            } catch (error) { console.error(error); }
        }
    }

    async function emptyCart() {
        const result = await Swal.fire({
            title: '¿Vaciar carrito completo?',
            text: "¡No podrás revertir esta acción!",
            icon: 'error',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: '¡Sí, vaciarlo!',
            cancelButtonText: 'Cancelar'
        });

        if (result.isConfirmed) {
            try {
                const response = await fetch(`/api/carts/${cartId}`, { method: 'DELETE' });
                if (response.ok) {
                    Toastify({ text: "Carrito vaciado", duration: 1500, style: { background: "#dc2626", borderRadius: "8px" } }).showToast();
                    setTimeout(() => window.location.reload(), 1500);
                }
            } catch (error) { console.error(error); }
        }
    }

</script>
