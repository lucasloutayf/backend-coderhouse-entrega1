<div style="max-width: 600px; margin: 2rem auto; background: white; padding: 2.5rem; border-radius: 0.5rem; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
    <a href="/products" style="color: #6b7280; text-decoration: none; font-weight: 500;">← Volver al catálogo</a>
    
    <h1 style="color: #0b5f1e; margin: 1.5rem 0 0.5rem 0; font-weight: 700;">{{product.title}}</h1>
    
    <div style="margin: 1.5rem 0;">
        <p style="margin-bottom: 1rem; line-height: 1.6; color: #4b5563;">{{product.description}}</p>
        <div style="background: #f3f4f6; padding: 1rem; border-radius: 0.5rem;">
            <p style="margin: 0 0 0.5rem 0;"><strong>Categoría:</strong> {{product.category}}</p>
            <p style="margin: 0 0 0.5rem 0;"><strong>Código interno:</strong> {{product.code}}</p>
            <p style="margin: 0;"><strong>Unidades disponibles:</strong> {{product.stock}}</p>
        </div>
    </div>
    
    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid #e5e7eb;">
        <h2 style="margin: 0; font-size: 2.5rem; font-weight: 700; color: #111827;">${{product.price}}</h2>
        <button onclick="addToCart('{{cartId}}', '{{product._id}}')" style="background-color: #0b5f1e; color: white; border: none; padding: 1rem 2rem; border-radius: 0.5rem; font-weight: 600; cursor: pointer; font-size: 1.1rem; transition: background-color 0.2s;">
            Agregar al Carrito
        </button>
    </div>
</div>

<script>
    async function addToCart(cartId, productId) {
        try {
            const response = await fetch(`/api/carts/${cartId}/product/${productId}`, { method: 'POST' });
            if (response.ok) {
                Toastify({
                    text: "¡Producto sumado al carrito! 🛍️",
                    duration: 3000,
                    gravity: "bottom", position: "right",
                    style: { background: "#0b5f1e", borderRadius: "8px", fontFamily: "Poppins, sans-serif" }
                }).showToast();
            } else {
                Toastify({ text: "Error al agregar", duration: 3000, style: { background: "#dc2626", borderRadius: "8px" } }).showToast();
            }
        } catch (error) { console.error(error); }
    }
</script>
